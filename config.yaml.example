# Copy to config.yaml and fill in your own sender details.
# See SLAP_BUILD_PROMPT.md §4 for the full schema; slap/config.py enforces it.
sender:
  from_email: everythingforgenius@gmail.com
  from_name: <Owner Name>

# Used to fill {{signature}} in every campaign template — required (can be
# an empty string "" to send with no signature, but the key itself must be
# present; see slap/config.py's load_global_config).
signature: |-
  <Your Name>
  <link — e.g. LinkedIn>
  <link — e.g. GitHub or portfolio>

gmass:
  api_key_env: GMASS_API_KEY # read from env; never store the key here

personas: # cadences are FIXED per persona
  hiring_manager: { stages: [2, 4, 6] }
  recruiter: { stages: [2, 3, 5] }
  founder: { stages: [2, 5, 7] }

schedule:
  fire_window_start: "09:00" # runner rolls a random fire moment in this window
  fire_window_end: "09:15"
  send_delay_min: 10 # seconds between emails during a drain
  send_delay_max: 15
  daily_cap: 500 # Gmail ceiling; drain stops here, overflow re-queues
  drain_retries: 3 # transient-failure retries before surfacing run_failed
  active_days: [mon, tue, wed, thu, fri] # days the unattended runner may drain (skip weekends here)

tracking:
  consumer_domains_file: consumer_domains.txt

# Optional — entirely omittable. Caches GMass reply/click/bounce data for
# the dashboard, refreshed hourly by `slap.py sync` (see LAUNCHD.md) instead
# of on every page load. If this block (or Redis itself) isn't there, the
# dashboard just falls back to live polling on open, exactly like before —
# `doctor` reports whether Redis is actually reachable, but never blocks a
# send/drain over it either way.
redis:
  url: redis://localhost:6379/0
