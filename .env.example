# Copy to .env and fill in. .env is gitignored — never commit the real key.
GMASS_API_KEY=

# Optional. Folder to populate with symlinks (not copies) back to every
# résumé PDF ever staged, named <company>-<role>-<date>.pdf, so there's one
# place to browse everything SLAP has ever sent. Leave blank to disable —
# archiving is off by default and never blocks a send either way.
RESUME_ARCHIVE_DIR=
